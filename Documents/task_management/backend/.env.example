# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/taskflow

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=taskflow_super_secret_jwt_key_2026_replace_this
JWT_EXPIRES_IN=7d

# ── Cookie ────────────────────────────────────────────────────────
COOKIE_MAX_AGE_MS=604800000

# ── CORS ──────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173